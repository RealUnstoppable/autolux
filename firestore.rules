rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // Admins are identified by an 'isAdmin' field on their user document
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.get('isAdmin', false) == false;
      allow update: if isAdmin() || (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin']));
      allow delete: if isAdmin();
    }

    // Bookings Collection (Detailing Requests)
    match /bookings/{bookingId} {
      // Clients can create new bookings, ensuring their own userId is attached
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      // Clients can read and update their own bookings (e.g. cancel), admins can read/update all
      allow read, update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only admins can delete bookings
      allow delete: if isAdmin();
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Detailing Plans Collection
    match /detailing_plans/{planId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      // Clients can read and update their own plans, admins can read/update all
      allow read, update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /detailingPlans/{planId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Inquiries Collection
    match /inquiries/{inquiryId} {
      allow create: if true; // Public can create
      allow read, update, delete: if isAdmin();
      // Clients can read their own plans, admins can read all
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);

      // Only admins can create/update/delete detailing plans
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
    match /detailingPlans/{planId} {
      allow read, update, delete: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    // Reviews Collection
    match /reviews/{reviewId} {
      allow read: if resource.data.status == 'approved' || isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;

      // Only admins can update (e.g. approve) or delete reviews
      allow update, delete: if isAdmin();
    }

    // Newsletter Subscribers
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Carts collection (needed for admin.html according to memory)
    match /carts/{cartId} {
      allow read: if isAdmin() || (isAuthenticated() && request.auth.uid == cartId);
      allow create: if isAdmin() || (isAuthenticated() && request.auth.uid == cartId);
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == cartId);
      allow delete: if isAdmin() || (isAuthenticated() && request.auth.uid == cartId);
      allow update, delete: if isAdmin();
    }

    // Additional rules needed for admin.html components
    match /carts/{cartId} {
      allow read, update, delete: if isAdmin() || (isAuthenticated() && request.auth.uid == cartId);
      allow create: if isAuthenticated() && request.auth.uid == cartId;
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /feature_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /site_stats/{docId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /newsletterSubscribers/{email} {
      allow read: if isAdmin();
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Admin protected collections
    match /carts/{cartId} {
      allow read, write: if isAdmin() || (isAuthenticated() && request.auth.uid == cartId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }

    match /feature_requests/{requestId} {
      allow create: if isAuthenticated();
      allow read, write: if isAdmin();
    }

    match /site_stats/{docId} {
      allow read, write: if isAdmin();
    }

    // Default catch-all deny
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Default deny for any other collections
    match /{document=**} {
      allow read: if false;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /quotes/{quoteId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /feature_requests/{requestId} {
      allow read, update, delete: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /site_stats/{docId} {
      allow read, write: if isAdmin();
    }

    match /newsletterSubscribers/{email} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Default catch-all: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
