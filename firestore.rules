rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Function to check if the user is an admin
    function isAdmin() {
      // Check the users collection for the isAdmin field
      return request.auth != null && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Default rule: Deny everything
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for detailing requests
    match /detailingRequests/{requestId} {
      allow create: if true;
      allow read, update, delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Rules for reviews
    match /reviews/{reviewId} {
      allow create: if request.auth != null;
      allow read: if resource.data.status == "approved" || isAdmin();
      allow update, delete: if isAdmin();
    }

    // Rules for newsletter subscribers
    match /newsletterSubscribers/{email} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Rules for users
    match /users/{userId} {
      allow create: if request.auth != null && request.auth.uid == userId;
      allow read, update: if isAdmin() || (request.auth != null && request.auth.uid == userId);
      allow delete: if isAdmin();
    }

    // Additional rules needed for admin.html
    match /carts/{cartId} {
      allow read: if isAdmin() || (request.auth != null && request.auth.uid == cartId);
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == cartId);
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
      allow create: if true;
    }

    match /quotes/{quoteId} {
      allow read, write: if isAdmin();
      allow create: if true;
    }

    match /feature_requests/{requestId} {
      allow read, write: if isAdmin();
      allow create: if request.auth != null;
    }

    match /site_stats/{docId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
  }
}
